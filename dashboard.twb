      <aliases enabled='yes' />
      <column caption='Acquition Rate' datatype='real' name='[Calculation_1317783905697794]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [status] = &quot;acquired&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([status])' />
      </column>
      <column caption='Closed Rate' datatype='real' name='[Calculation_1317783905771523]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;    IF [status] = &quot;closed&quot; THEN 1 ELSE 0 END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([status])' />
      </column>
      <column caption='Acquired Funding' datatype='integer' name='[Calculation_1564349352312832]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [status] = &quot;acquired&quot; THEN&#13;&#10;    [funding_total_usd]&#13;&#10;END' />
      </column>
      <column caption='Closed Funding' datatype='integer' name='[Calculation_1564349352693761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [status] = &quot;closed&quot; THEN&#13;&#10;    [funding_total_usd]&#13;&#10;END' />
      </column>
      <column caption='Funding Gap' datatype='real' name='[Calculation_1564349352775682]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([Calculation_1564349352312832]) - MEDIAN([Calculation_1564349352693761])' />
      </column>
      <column caption='log_total_funding' datatype='real' name='[Calculation_1564349353271299]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG([funding_total_usd])' />
      </column>
      <column caption='Funding_round_group' datatype='string' name='[Calculation_1564349357903876]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [funding_rounds] &gt;= 6 THEN&#13;&#10;    &quot;6+&quot;&#13;&#10;ELSE&#13;&#10;    STR(INT([funding_rounds]))&#13;&#10;END' />
      </column>
